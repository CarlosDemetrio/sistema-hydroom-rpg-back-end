# =====================================================================
# Template de variaveis de ambiente - Producao OCI
# =====================================================================
# Copie este arquivo para /opt/app/.env na VM e preencha os valores reais.
# NUNCA commite o .env real no repositorio!

# Database PostgreSQL
DB_USERNAME=rpg_prod_user
DB_PASSWORD=GERAR_SENHA_FORTE_AQUI
POSTGRES_DB=rpg_fichas

# GitHub Container Registry
GHCR_OWNER=carlosdemetrio

# URLs (substituir pelo dominio real)
# Frontend: https://seu-dominio.com (servido por Caddy como arquivos estaticos)
# Backend:  https://api.seu-dominio.com (reverse proxy para Spring Boot)
FRONTEND_URL=https://seu-dominio.com
BACKEND_URL=https://api.seu-dominio.com

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary (futuro - deixe vazio)
CLOUDINARY_URL=

# Tag da imagem Docker (gerenciado automaticamente pelo deploy)
IMAGE_TAG=latest
